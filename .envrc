# direnv auto-activates the Isaac Lab venv and sources deploy env setup
# on `cd` into this repo. Run `direnv allow` once after cloning.

# Guard so `direnv reload` / re-entry after activate doesn't double-source.
if [ -z "${VIRTUAL_ENV:-}" ] || [ "${VIRTUAL_ENV}" != "$PWD/.venv_isaac" ]; then
    if [ -f .venv_isaac/bin/activate ]; then
        source .venv_isaac/bin/activate
    else
        echo "[.envrc] .venv_isaac not found; see sonic_python_inference/README.md #Setup" >&2
    fi
fi

if [ -f gear_sonic_deploy/scripts/setup_env.sh ]; then
    source gear_sonic_deploy/scripts/setup_env.sh
fi
